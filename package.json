{
  "name": "monitoring-system",
  "version": "1.0.0",
  "description": "Sistema de monitoramento de infraestrutura estilo Zabbix/Prometheus, construído com stack moderna e pronto para produção.",
  "main": "ingest-api/index.js",
  "scripts": {
    "start": "node ingest-api/index.js",
    "dev": "NODE_ENV=development node ingest-api/index.js",
    "postinstall": "npm install --prefix ingest-api",
    "test": "echo \"Error: no test specified\" && exit 1",
    "install-deps": "npm install && cd ingest-api && npm install && cd ../websocket-server && npm install && cd ../frontend && npm install && cd ..",
    "docker-build": "docker-compose build",
    "docker-up": "docker-compose up -d",
    "docker-down": "docker-compose down",
    "docker-logs": "docker-compose logs -f"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SEU_USUARIO/monitoring-system.git"
  },
  "keywords": [
    "monitoring",
    "infrastructure",
    "zabbix",
    "prometheus",
    "metrics",
    "alerts"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "bugs": {
    "url": "https://github.com/SEU_USUARIO/monitoring-system/issues"
  },
  "homepage": "https://github.com/SEU_USUARIO/monitoring-system#readme",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "eslint": "^8.54.0"
  }
}
