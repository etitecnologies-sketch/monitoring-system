# ── Database ───────────────────────────────────────────── 
DATABASE_URL=postgresql://monitor:changeme@db:5432/monitoring
DB_USER=monitor
DB_PASSWORD=changeme
DB_NAME=monitoring

# ── JWT & Auth ──────────────────────────────────────────── 
JWT_SECRET=changeme-secret-jwt

# ── Services URLs ──────────────────────────────────────── 
WEBSOCKET_URL=http://websocket:3001
INGEST_URL=http://ingest-api:3000/metrics

# ── Ports ───────────────────────────────────────────────── 
PORT=3000 
WEBSOCKET_PORT=3001 
FRONTEND_PORT=80 

# ── Agent Configuration ─────────────────────────────────── 
DEVICE_TOKEN=your-device-token-here 

# ── Processor Configuration ─────────────────────────────── 
EVAL_INTERVAL=3 
OFFLINE_TIMEOUT=60 
ALERT_COOLDOWN=120 
PING_TIMEOUT=3 
PING_COUNT=1 

# ── Telegram Alerts (Optional) ──────────────────────────── 
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ── Email Alerts (Optional) ─────────────────────────────── 
SMTP_HOST=smtp.gmail.com 
SMTP_PORT=587 
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL=

# ── CORS Configuration ──────────────────────────────────── 
CORS_ORIGIN=*

# ── Environment ─────────────────────────────────────────── 
NODE_ENV=development 
PYTHON_ENV=development 

# ── Frontend Configuration ──────────────────────────────── 
VITE_WEBSOCKET_URL=ws://localhost:3001
