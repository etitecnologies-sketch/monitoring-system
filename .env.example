# Database
DATABASE_URL=postgres://monitor:changeme@localhost:5432/monitoring
DB_PASSWORD=changeme
DB_USER=monitor
DB_NAME=monitoring

# Security
JWT_SECRET=generate-a-long-random-string-here
CORS_ORIGIN=*
COLLECTOR_KEY=generate-a-long-random-string-here
ONVIF_CRED_SECRET=generate-a-long-random-string-here
CLIENT_ID=

# URLs
WEBSOCKET_URL=http://localhost:3001
WEBSOCKET_PUBLISH_KEY=generate-a-long-random-string-here
WS_REQUIRE_AUTH=false
INGEST_URL=http://localhost:3000/metrics

# Alerts (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
ALERT_EMAIL=destination@email.com
TELEGRAM_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# Processor Config
EVAL_INTERVAL=1
OFFLINE_TIMEOUT=30
ALERT_COOLDOWN=60
