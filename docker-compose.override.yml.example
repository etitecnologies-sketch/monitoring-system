# Development override configuration
# This file is git-ignored and provides local development settings
# Copy to docker-compose.override.yml

version: "3.8"

services:
  ingest-api:
    environment:
      - NODE_ENV=development
      - DEBUG=*
    ports:
      - "3000:3000"
    volumes:
      - ./ingest-api:/app
      - /app/node_modules
    command: npm run dev

  websocket:
    environment:
      - NODE_ENV=development
      - DEBUG=*
    ports:
      - "3001:3001"
    volumes:
      - ./websocket-server:/app
      - /app/node_modules
    command: npm run dev

  processor:
    environment:
      - PYTHONUNBUFFERED=1
      - NODE_ENV=development
    volumes:
      - ./processor:/app
    command: python main.py

  frontend:
    environment:
      - VITE_API_URL=http://localhost:3000
      - VITE_WEBSOCKET_URL=ws://localhost:3001
    ports:
      - "5173:5173"
    volumes:
      - ./frontend:/app
      - /app/node_modules
    command: npm run dev

  db:
    ports:
      - "5432:5432"
    environment:
      - POSTGRES_PASSWORD=postgres
    volumes:
      - postgres_data_dev:/var/lib/postgresql/data

volumes:
  postgres_data_dev:
    driver: local
